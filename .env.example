# =============================================================================
# Sao chép file này thành .env và điền giá trị thật.
# Không commit .env lên git (chứa secret).
# =============================================================================

# -----------------------------------------------------------------------------
# LLM — chọn MỘT cấu hình phù hợp (bỏ comment block bạn dùng).
# Code: server/llm.js  |  AI Agent: server/ai-agent.js
# -----------------------------------------------------------------------------

# --- Chung ---
# AI_PROVIDER: gemini | openai | custom | http | local | auto
# - auto: nếu có GEMINI_API_KEY (không rỗng) thì dùng Gemini; muốn ưu tiên gateway HTTP trong khi vẫn giữ dòng GEMINI trong file → AI_PREFER_HTTP_LLM=1
#   không thì HTTP nếu có AI_CUSTOM_LLM_URL / URL OpenAI-compatible / key HTTP.
# AI_PROVIDER=auto
#
# Ưu tiên gateway HTTP thay vì Gemini (tuỳ chọn hiếm khi cần):
# AI_PREFER_HTTP_LLM=1

# --- 1) Google Gemini ---
# AI_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# (Tuỳ chọn) AI_MODEL=...  — fallback tên model nếu không set GEMINI_MODEL

# --- 2) OpenAI hoặc API tương thích OpenAI (OpenRouter, Azure OpenAI qua base URL, vLLM, một số gateway) ---
# AI_PROVIDER=openai
# AI_OPENAI_API_KEY=
# Hoặc: OPENAI_API_KEY=  hoặc  AI_API_KEY=
# AI_OPENAI_BASE_URL=https://api.openai.com/v1
# AI_OPENAI_MODEL=gpt-4o-mini

# Ví dụ OpenRouter (kiểm tra docs provider về base URL và header):
# AI_PROVIDER=openai
# AI_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# AI_OPENAI_API_KEY=
# AI_OPENAI_MODEL=openai/gpt-4o-mini
# AI_EXTRA_HEADERS_JSON={"HTTP-Referer":"https://your-site.example","X-Title":"jira-agent"}

# --- 3) Gateway / provider tự host (LM Studio, llama.cpp server, v.v.) ---
# API kiểu OpenAI: POST {base}{AI_HTTP_COMPLETIONS_PATH} với body model + messages.
#
# Ví dụ A — chỉ host:port (server tự thêm http://):
# AI_PROVIDER=custom
# AI_CUSTOM_LLM_URL=localhost:20128/v1
#
# Ví dụ B — URL đầy đủ:
# AI_CUSTOM_LLM_URL=http://127.0.0.1:20128/v1
#
# Ví dụ C — app chạy trong Docker, model chạy trên máy host (Windows/Mac):
# AI_CUSTOM_LLM_URL=host.docker.internal:20128/v1
#
# Tên model do server bạn quy định (LM Studio hiển thị trong UI):
# AI_MODEL=local-model-name
# Hoặc: AI_OPENAI_MODEL=...

# Không gửi Bearer (server local không cần key). Mặc định localhost/127.0.0.1 cho phép không key;
# nếu cần ép: AI_HTTP_ALLOW_NO_AUTH=1  |  ép có key: AI_HTTP_ALLOW_NO_AUTH=0 và đặt AI_API_KEY=...
# AI_HTTP_ALLOW_NO_AUTH=1

# Path completions (mặc định /v1/chat/completions). Đổi nếu gateway dùng path khác:
# AI_HTTP_COMPLETIONS_PATH=/v1/chat/completions

# Header bổ sung (JSON object). Ví dụ Azure / custom gateway:
# AI_EXTRA_HEADERS_JSON={"api-key":"YOUR_KEY"}

# OpenAI Organization (chỉ khi dùng OpenAI chính thức):
# OPENAI_ORGANIZATION=

# Timeout HTTP LLM (ms), nhiệt độ sampling:
# AI_HTTP_TIMEOUT_MS=120000
# AI_TEMPERATURE=0.2
#
# Embedding (code search / project assistant). Dùng "auto" để chọn model /embed từ gateway.
# Tránh openai/text-embedding-* nếu gateway không cấu hình credential OpenAI.
# AI_EMBEDDING_MODEL=auto

# -----------------------------------------------------------------------------
# AI Agent — retry & context (tuỳ chọn, server/ai-agent.js)
# -----------------------------------------------------------------------------

# Số lần retry khi LLM trả 429 / rate limit (mỗi lần gọi generate):
# AI_LLM_HTTP_RETRIES=8
# (Alias cũ) AI_GEMINI_HTTP_RETRIES=8

# Sau khi build fail: số vòng AI tự sửa (mặc định 4). -1 hoặc unlimited = không giới hạn (dễ tốn quota).
# AI_MAX_VERIFY_RETRIES=4
# AI_VERIFY_RETRY_DEFAULT=4

# Trước khi chạy npm/dotnet build: gọi LLM review patch — nếu chỉ đổi text/copy/UI đơn giản thì bỏ qua verify để nhanh hơn (mặc định bật). Tắt = luôn build như cũ.
# AI_VERIFY_TRIVIAL_GATE=1
# AI_VERIFY_TRIVIAL_GATE=0

# Giới hạn context (mặc định nhỏ: ~72 file context, ~32 planning; git grep ưu tiên tín hiệu từ EXPERT SKILLS rồi mới ticket).
# Tăng quét: nâng AI_MAX_CONTEXT_FILES / AI_GREP_MAX_TOTAL_FILES (tốn token).
# AI_MAX_CONTEXT_FILES=72
# AI_MAX_PLANNING_FILES=32
# AI_MAX_PROMPT_FILES=28
# AI_MAX_PROMPT_FILES_WITH_PLAN=16
# AI_MAX_SKILLS_CHARS=22000
# Token từ skill để boost điểm path (path + từ dài trong skill):
# AI_SKILL_SCORE_TOKEN_CAP=40
# AI_MAX_ACTIVE_SKILLS=8
# AI_MAX_SINGLE_SKILL_CHARS=7000
# Ghi chú:
# - Không set hoặc set <= 0 => không giới hạn (load theo selected_skills của Project).
# - Chỉ dùng 2 biến trên khi muốn ép giới hạn cứng để giảm token.
# AI_MAX_FILE_SNIPPETS=8
# AI_MAX_FILE_SNIPPET_CHARS=1200
# AI_MAX_FILE_CONTEXT_CHARS=14000
# AI_PROMPT_NEIGHBOR_CAP=2
# Git grep (tắt: AI_GREP_ENABLE=0). Tín hiệu: skill trước, ticket sau (tối đa AI_GREP_MAX_SIGNALS).
# AI_GREP_MAX_SIGNALS=22
# AI_GREP_MAX_FILES_PER_SIGNAL=12
# AI_GREP_MAX_TOTAL_FILES=48
# AI_SYMBOL_HINT_COUNT=22
# AI_SYMBOL_FILE_HINT_LIMIT=28
# Đoạn skill đưa vào query symbol search (ký tự):
# AI_SYMBOL_SKILL_CHARS=2000
# Số dòng symbol gửi vào prompt planning:
# AI_SYMBOL_HINT_DISPLAY=20
# Số file đầu planning dùng làm Deep Research (snippet tóm tắt cho planner):
# AI_RESEARCH_FILE_COUNT=8

# Bước LLM path-suggest (trước planning): model chỉ thấy STT + basename (+ thư mục rút nếu trùng tên). Tắt: AI_PATH_SUGGEST_ENABLE=0
# AI_PATH_SUGGEST_POOL_LINES=600
# AI_PATH_SUGGEST_MAX_PICK=28
# AI_PATH_SUGGEST_SKILL_CHARS=8000
# AI_PATH_SUGGEST_CONTEXT_CHARS=4000

# Planning: chỉ mục repo — mặc định dupes (basename trùng nhiều path) để tránh vượt ~128k token; full=list path dài.
# AI_PLANNING_REPO_INDEX_MODE=dupes
# AI_PLANNING_REPO_INDEX_MODE=basenames
# AI_PLANNING_REPO_INDEX_MODE=full
# AI_PLANNING_REPO_INDEX_DISABLE=1
# AI_PLANNING_REPO_INDEX_MAX_LINES=2800
# AI_PLANNING_REPO_INDEX_MAX_CHARS=72000
# Số basename trùng tối đa hiển thị (mode dupes); mỗi basename tối đa bao nhiêu path đầy đủ:
# AI_PLANNING_REPO_INDEX_DUPE_ROWS=450
# AI_PLANNING_REPO_INDEX_DUPE_PATHS_EACH=10
# Snippet đầu mỗi file trong prompt planning (mặc định 36 dòng/file):
# AI_PLANNING_SUMMARY_MAX_LINES=36
# Giới hạn ký tự nội dung skill gửi kèm bước planning (khác AI_MAX_SKILLS_CHARS của bước fix):
# AI_PLANNING_EXPERT_SKILLS_MAX_CHARS=18000

# AI_MAX_CHANGE_FILES=25
# AI_MAX_CHANGE_LINES_PER_FILE=1200

# Git grep gợi ý file theo ticket (tắt nếu môi trường không có git đúng cwd):
# AI_GREP_ENABLE=1
# AI_GREP_MAX_SIGNALS=32
# AI_GREP_MAX_FILES_PER_SIGNAL=42
# AI_GREP_MAX_TOTAL_FILES=240

# Git commit author khi AI push (ai-agent): project phải có git_user là email — xem UI Projects.

# Bộ nhớ kinh nghiệm theo project (DB: app_projects.ai_project_memory). Luôn nén qua LLM (đọc + ghi) trừ khi tắt:
# AI_PROJECT_MEMORY_DISABLE=1
# AI_PROJECT_MEMORY_LLM=0
# AI_PROJECT_MEMORY_MAX_ENTRIES=25
# AI_PROJECT_MEMORY_MAX_LESSON_CHARS=2200
# AI_PROJECT_MEMORY_LLM_READ_CHARS=900
# AI_PROJECT_MEMORY_LLM_STORE_CHARS=700
# AI_PROJECT_MEMORY_LLM_INPUT_CHARS=12000
# AI_PROJECT_MEMORY_LLM_STORE_MIN_CHARS=120
# AI_PROJECT_MEMORY_LOG_FAILURES=0

# When user rejects a plan with feedback, replan prompt includes old plan/log/reasoning/changes (truncated per field).
# AI_REPLAN_MAX_PLAN_CHARS=30000
# AI_REPLAN_MAX_LOG_CHARS=20000
# AI_REPLAN_MAX_REASONING_CHARS=12000
# AI_REPLAN_MAX_CHANGES_CHARS=20000

# -----------------------------------------------------------------------------
# Jira
# -----------------------------------------------------------------------------
# JIRA_URL=https://your-jira.example.com
# JIRA_API_VERSION=v2
# Jira Token: mỗi user cấu hình trong app (Cấu hình cá nhân), không dùng biến môi trường.
# JIRA_PROJECT_KEY=PROJ

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=postgres

# -----------------------------------------------------------------------------
# Telegram (thông báo AI Agent)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Expert skills (AI Agent + UI Admin)
# -----------------------------------------------------------------------------
# Skill lưu trong PostgreSQL: bảng app_expert_skills (filename + body). Không còn git push cho skill.
# Lần đầu DB trống: server có thể seed một lần từ file trong server/skills/ (nếu thư mục tồn tại).
